{
  "name": "@cardspark/ui",
  "version": "0.1.0",
  "description": "React components and design tokens for Pokémon card collection interfaces.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Cardspark",
  "homepage": "https://cardspark.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardspark-ui/cardspark.git"
  },
  "bugs": {
    "url": "https://github.com/cardspark-ui/cardspark/issues"
  },
  "type": "module",
  "keywords": [
    "cardspark",
    "trading-cards",
    "tcg",
    "pokemon",
    "react",
    "ui",
    "components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "NOTICE.md",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && cp ../tokens/src/tokens.css dist/tokens.css && cp src/styles.css dist/styles.css && mkdir -p dist/themes dist/assets/pokemon && cp src/themes/*.css dist/themes/ && cp src/assets/pokemon/card-back.png dist/assets/pokemon/card-back.png",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "pretest:package": "npm run build",
    "test:package": "node test-package.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./collecting": {
      "types": "./dist/collecting/index.d.ts",
      "import": "./dist/collecting/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./market": {
      "types": "./dist/market/index.d.ts",
      "import": "./dist/market/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./styles.css": "./dist/styles.css",
    "./themes/basement.css": "./dist/themes/basement.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
